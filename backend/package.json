{
  "name": "erasofempire-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "pnpm -C ../packages/shared run build",
    "dev": "tsx watch src/index.ts",
    "prebuild": "pnpm -C ../packages/shared run build",
    "build": "tsc",
    "prestart": "pnpm -C ../packages/shared run build",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/postgres/migrate.ts",
    "seed": "tsx src/db/postgres/seed.ts",
    "seed:maps": "tsx ../database/seedMaps.ts",
    "pretest": "pnpm -C ../packages/shared run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:maps": "tsx scripts/validateMaps.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@erasofempire/shared": "workspace:*",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@sentry/node": "^10.49.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.73.4",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "firebase-admin": "^13.8.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.4",
    "nanoid": "^5.0.7",
    "nodemailer": "^8.0.5",
    "pg": "^8.11.5",
    "postgres": "^3.4.4",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^3.0.5"
  }
}
