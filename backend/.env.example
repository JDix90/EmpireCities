# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
# Comma-separated extra CORS + Socket.IO origins (Capacitor, staging web, etc.)
# CORS_ORIGINS=https://app.example.com,capacitor://localhost
# Cross-site refresh cookie: strict | lax | none (none requires HTTPS + Secure)
# REFRESH_COOKIE_SAME_SITE=lax

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=chronouser
POSTGRES_PASSWORD=chronopass
POSTGRES_DB=borderfall

# Legacy MongoDB (only for one-time migrate:maps-from-mongo — maps now live in Postgres)
# MONGO_URI=mongodb://chronouser:chronopass@localhost:27017/borderfall_maps?authSource=admin

# Redis (matches docker-compose.yml default password)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=chronoredis

# JWT
JWT_ACCESS_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# SMTP (optional — async turn notifications + password reset emails)
# FRONTEND_URL must match the web app origin so reset links point to /reset-password correctly.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@borderfall.com

# When SMTP is unset or send fails in non-production, set true to log the full reset URL server-side
# (see backend logs) so you can complete forgot-password flows locally without mail.
# PASSWORD_RESET_DEV_LOG=true

# Firebase Cloud Messaging (optional — for push notifications)
# Path to the Firebase service account JSON file
FCM_SERVICE_ACCOUNT_PATH=

# Admin bootstrapping
# After running migrations on a fresh database, grant admin to the first user via:
#   pnpm --filter backend run grant-admin -- your@email.com
# No env var required — the script takes the email as a CLI argument.

# Ops / observability (90-day roadmap)
# SENTRY_DSN=
# Set true to record the product-analytics funnel — persists to the analytics_events
# table (read via scripts/funnelReport.ts) and emits one JSON log line per event.
# ANALYTICS_EVENTS_ENABLED=false
# Set false to disable GET /metrics/json (default: enabled)
# METRICS_ENDPOINT_ENABLED=true

# Watch/Spectate surface (Live nav, lobby Watch entries, /api/games/live,
# spectator joins). Default off — at low player counts the live list is mostly
# empty or stale. Also flippable live via the spectate_enabled admin override.
# SPECTATE_ENABLED=false

# Retention (see docs/RETENTION-PLAYBOOK.md)
# One-time guest → create-account nudge after a finished game (default off).
# SIGNUP_NUDGE_ENABLED=false
# Hourly re-engagement sweep: streak-at-risk push, daily-challenge reminder,
# D2/D7 win-back email. Worker always starts; sends are gated by this flag
# (also flippable live via the retention_notifications_enabled admin override).
# RETENTION_NOTIFICATIONS_ENABLED=false
# HMAC secret for one-click email-unsubscribe links (falls back to
# JWT_ACCESS_SECRET when unset; set it so rotating JWT secrets doesn't break
# unsubscribe links already sitting in inboxes).
# UNSUBSCRIBE_TOKEN_SECRET=
