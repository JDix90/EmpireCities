# Copy to .env.production and fill in before:
#   docker compose -f docker/docker-compose.prod.yml --env-file .env.production up -d
#
# IMPORTANT: never commit your real .env.production. Treat the values below as
# inert placeholders; do not reuse them in a real deploy. Generate fresh
# secrets with `openssl rand -hex 32` for every JWT/DB credential.

# Public URL users type in the browser (scheme + host, no trailing path). Used for CORS + Socket.io.
# STRONGLY recommended: use https in production. http is only acceptable
# behind a load balancer that already terminates TLS, never as the URL users hit directly.
# Examples: https://play.example.com  or  https://203.0.113.50
FRONTEND_URL=https://your-domain.example.com

# Optional extra allowed origins (comma-separated), e.g. https://www.example.com
# CORS_ORIGINS=

# Postgres credentials. Avoid @ # : in passwords or URL-encode them.
POSTGRES_USER=replace_me_postgres_user
POSTGRES_PASSWORD=replace_me_with_openssl_rand_hex_32
POSTGRES_DB=borderfall

REDIS_PASSWORD=replace_me_with_openssl_rand_hex_32

# Optional — unique id per backend instance when running multiple nodes (Phase 9).
# INSTANCE_ID=backend-1

# Required for production — generate with `openssl rand -hex 32` (DO NOT reuse the placeholder).
# Validation will refuse to boot if either secret is empty, shorter than 32 chars,
# or matches a known development default.
JWT_ACCESS_SECRET=replace_me_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=replace_me_with_openssl_rand_hex_32

# lax = same-site-ish; use none + Secure cookies only if you know you need cross-site cookies.
REFRESH_COOKIE_SAME_SITE=lax

# Optional: force refresh cookie Secure flag (`true` or `false`).
# If omitted, backend auto-detects from FRONTEND_URL scheme:
# - https FRONTEND_URL -> Secure cookie enabled
# - http  FRONTEND_URL -> Secure cookie disabled
# REFRESH_COOKIE_SECURE=

# Host port published for nginx (default 80). When TLS terminates upstream
# (recommended), publish 443 instead and configure the reverse proxy.
HTTP_PORT=127.0.0.1:8080

# Leave empty for same-origin Docker stack (nginx proxies /api and /socket.io).
# Set only for split deploy (static on CDN, API on another host):
# VITE_API_URL=https://api.example.com
# VITE_SOCKET_URL=https://api.example.com

# Optional: Sentry for frontend error reporting (baked into SPA at build time)
# VITE_SENTRY_DSN=https://...@....ingest.sentry.io/...

# Optional: support email shown on Privacy/Terms pages (defaults to support@borderfall.com)
# VITE_SUPPORT_EMAIL=support@your-domain.com

# ── Backend observability & email (passed to backend container) ──────────────
# SENTRY_DSN=https://...@....ingest.sentry.io/...

# SMTP — password reset + async turn notifications (recommended for production)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_KbBDb25X_7ZfQ9LKkzhHACZgqiNZnCHmK
# SMTP_FROM=noreply@borderfall.gg
