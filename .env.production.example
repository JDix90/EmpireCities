# Copy to .env.production and fill in before: docker compose -f docker/docker-compose.prod.yml --env-file .env.production up -d

# Public URL users type in the browser (scheme + host, no trailing path). Used for CORS + Socket.io.
# Examples: https://play.example.com  or  http://203.0.113.50
FRONTEND_URL=http://143.198.73.58

# Optional extra allowed origins (comma-separated), e.g. https://www.example.com
# CORS_ORIGINS=

# Map Mongo password in URI — avoid @ # : in passwords or URL-encode them.
POSTGRES_USER=chronouser
POSTGRES_PASSWORD=0c4ae0e9ad13a06939c5f49e2c315c0836f10451df80bed5
POSTGRES_DB=erasofempire

MONGO_USER=chronouser
MONGO_PASSWORD=change_me_strong_mongo
MONGO_DB=erasofempire_maps

REDIS_PASSWORD=change_me_strong_redis

# Required for production — use long random strings (openssl rand -hex 32)
JWT_ACCESS_SECRET=b69967554aec153e76e56d00199b6c93e2a68bc4b10f55bf68de1694afb92fdb
JWT_REFRESH_SECRET=a17f9458fdd2dcffa97bf082e76273e056251581cd1e29c4ad1a986894c74c6f


# lax = same-site-ish; use none + Secure cookies only if you know you need cross-site cookies.
REFRESH_COOKIE_SAME_SITE=lax

# Host port published for nginx (default 80)
HTTP_PORT=80

# Leave empty for same-origin Docker stack (nginx proxies /api and /socket.io).
# Set only for split deploy (static on CDN, API on another host):
# VITE_API_URL=https://api.example.com
# VITE_SOCKET_URL=https://api.example.com
