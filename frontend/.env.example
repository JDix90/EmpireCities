# ─────────────────────────────────────────────────────────────────────────────
# ChronoConquest Frontend — Environment Variables
# Copy this file to .env and fill in your values before running.
# ─────────────────────────────────────────────────────────────────────────────

# Vite exposes variables prefixed with VITE_ to the browser.
# The API proxy in vite.config.ts handles /api → localhost:3001 automatically
# during development, so no VITE_API_URL is needed locally.

VITE_APP_TITLE=ChronoConquest
VITE_APP_VERSION=1.0.0
