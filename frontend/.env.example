# Optional — omit in local dev to use Vite proxy to backend (see vite.config.ts).
# Set for production web hosting or Capacitor builds pointing at your API.
#
# VITE_API_URL=https://api.yourdomain.com
# VITE_SOCKET_URL=https://api.yourdomain.com

# Optional: Sentry frontend error reporting (production / store builds)
# VITE_SENTRY_DSN=https://...@....ingest.sentry.io/...

# Optional: support email on Privacy/Terms pages (default: support@borderfall.com)
# VITE_SUPPORT_EMAIL=support@yourdomain.com

# Optional: Firebase web push (requires firebase-messaging-sw.js config)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_VAPID_KEY=
